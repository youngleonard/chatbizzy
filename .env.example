# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — do NOT commit your real keys.

# Google AI Studio API key for Gemini
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key_here

# Vercel Postgres connection string. Get this from the Storage tab in your
# Vercel project after creating a Postgres database and linking it.
POSTGRES_URL=postgres://user:password@host/db?sslmode=require
